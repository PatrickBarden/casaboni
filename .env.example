# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: Optional local server port.
PORT=3000

# Firebase/Firestore (optional override for Casaboni production project).
# If omitted, values from firebase-applet-config.json are used.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_DATABASE_ID=""

# Firebase Admin (recommended for production CRM writes/upserts from the chat backend).
# Use either the full service account JSON or the split client email/private key.
FIREBASE_SERVICE_ACCOUNT_JSON=""
FIREBASE_PROJECT_ID=""
FIREBASE_DATABASE_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# n8n RAG webhook endpoint (optional but recommended)
# Example: https://your-n8n-domain/webhook/casaboni-rag-query
N8N_RAG_WEBHOOK_URL=""
N8N_DRIVE_FOLDER_ID=""

# n8n SDR agent webhook endpoint (recommended as primary chat brain)
# Example: https://your-n8n-domain/webhook/casaboni-sdr-agent
N8N_SDR_WEBHOOK_URL=""
